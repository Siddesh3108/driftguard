# DriftGuard — Environment Variables
# Copy to .env and fill in values before running docker compose

# Slack Incoming Webhook URL (optional — leave empty to disable)
# Create at: https://api.slack.com/apps > Incoming Webhooks
SLACK_WEBHOOK_URL=

# MLflow tracking server URI (used by API, worker, beat, and stream consumer)
MLFLOW_TRACKING_URI=http://mlflow:5000

# Redis connection (defaults match docker-compose service names)
REDIS_HOST=redis
REDIS_PORT=6379

# SQLite database path (relative to repo root, mounted into containers)
DRIFTGUARD_DB=data/driftguard.db

# Frontend CORS origin (lock this down to your real domain in production)
FRONTEND_ORIGIN=http://localhost:5173
